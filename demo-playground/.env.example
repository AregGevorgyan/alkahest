# AI Provider — anthropic, openai, google, mistral, groq, xai, deepseek,
# together, fireworks, cerebras, or openai-compatible
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# Provider API keys (only the one matching AI_PROVIDER is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=

# OpenAI-compatible endpoint (Ollama, vLLM, LiteLLM, etc.)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Python execution server URL (local or remote)
PYTHON_SERVER_URL=http://localhost:8000

# Optional auth for remote Alkahest server (Bearer token; WebSocket uses ?token=)
ALKAHEST_SERVER_TOKEN=

# Next.js public env (exposed to browser)
NEXT_PUBLIC_PYTHON_WS_URL=ws://localhost:8000
NEXT_PUBLIC_PYTHON_HTTP_URL=http://localhost:8000
